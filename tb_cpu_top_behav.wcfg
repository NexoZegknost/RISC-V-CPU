<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_cpu_top_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_cpu_top" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="80.400 ns"></ZoomStartTime>
      <ZoomEndTime time="175.001 ns"></ZoomEndTime>
      <Cursor1Time time="145.000 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="153"></NameColumnWidth>
      <ValueColumnWidth column_width="71"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="7" />
   <wvobject fp_name="/tb_cpu_top/clk" type="logic">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_cpu_top/rst" type="logic">
      <obj_property name="ElementShortName">rst</obj_property>
      <obj_property name="ObjectShortName">rst</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_cpu_top/uut/PC/pc_out" type="array">
      <obj_property name="ElementShortName">pc_out[4:0]</obj_property>
      <obj_property name="ObjectShortName">pc_out[4:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_cpu_top/uut/ir_out" type="array">
      <obj_property name="ElementShortName">ir_out[31:0]</obj_property>
      <obj_property name="ObjectShortName">ir_out[31:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_cpu_top/uut/ac_out" type="array">
      <obj_property name="ElementShortName">ac_out[31:0]</obj_property>
      <obj_property name="ObjectShortName">ac_out[31:0]</obj_property>
      <obj_property name="Radix">SIGNEDDECRADIX</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_cpu_top/uut/CTRL/state" type="array">
      <obj_property name="ElementShortName">state[2:0]</obj_property>
      <obj_property name="ObjectShortName">state[2:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_cpu_top/uut/MEM/ram" type="array">
      <obj_property name="ElementShortName">ram[0:31][31:0]</obj_property>
      <obj_property name="ObjectShortName">ram[0:31][31:0]</obj_property>
   </wvobject>
</wave_config>
